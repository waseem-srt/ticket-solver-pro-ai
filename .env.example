# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ticketuser:ticketpass@localhost:5432/ticketdb
DATABASE_URL_SYNC=postgresql://ticketuser:ticketpass@localhost:5432/ticketdb

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-very-long-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── HuggingFace ───────────────────────────────────────────────────────────────
HF_TOKEN=your_huggingface_token_here
HF_MODEL_REPO=Qwen/Qwen2.5-1.5B-Instruct
RUN_LOCAL_LLM=false

# ─── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chromadb
CHROMA_TICKETS_COLLECTION=ticket_knowledge_base
CHROMA_DOCUMENTS_COLLECTION=document_knowledge_base

# ─── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ─── RAG ───────────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_CONFIDENCE_THRESHOLD=0.4

# ─── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ─── DuckDuckGo (no key needed) ────────────────────────────────────────────────
WEB_SEARCH_MAX_RESULTS=5
